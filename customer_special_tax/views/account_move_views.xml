<odoo>
    <!-- Hide child contacts from customer/vendor selection in invoices -->
    <record id="view_move_form_hide_contacts" model="ir.ui.view">
        <field name="name">account.move.form.hide.contacts</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="attributes">
                <attribute name="domain">[('parent_id', '=', False)]</attribute>
            </field>
        </field>
    </record>
</odoo>