<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_journal_form_payment_fields" model="ir.ui.view">
        <field name="name">account.journal.form.payment.fields</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='advanced_settings']" position="after">
                <page string="Paiement" name="payment_fields">
                    <group>
                        <group string="Type de partenaire">
                            <field name="partner_type" widget="radio"/>
                            <field name="customer_id"
                                invisible="partner_type != 'customer'"/>
                            <field name="vendor_id"
                                invisible="partner_type != 'vendor'"/>
                            <field name="is_retenue_journal"/>
                        </group>
                        <group string="Type de paiement">
                            <field name="payment_type" widget="radio"/>
                        </group>
                    </group>
                    <group string="Details">
                        <field name="date_echeance"
                            invisible="payment_type not in ('cheque', 'traite')"/>
                        <field name="bank_name"
                            invisible="payment_type not in ('cheque', 'traite')"/>
                        <field name="bank_code"
                            invisible="payment_type not in ('cheque', 'traite')"/>
                        <field name="numero_cheque"
                            invisible="payment_type != 'cheque'"/>
                        <field name="numero_traite"
                            invisible="payment_type != 'traite'"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>