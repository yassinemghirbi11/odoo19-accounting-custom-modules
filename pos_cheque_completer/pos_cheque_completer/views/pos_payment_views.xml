<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_pos_cheque_completer_tree" model="ir.ui.view">
        <field name="name">pos.payment.cheque.completer.list</field>
        <field name="model">pos.payment</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <list string="Cheques a completer" create="false" delete="false">
                <field name="payment_date" readonly="1"/>
                <field name="session_id" readonly="1" optional="show"/>
                <field name="pos_order_id" readonly="1" optional="show"/>
                <field name="partner_id" readonly="1" optional="show"/>
                <field name="amount" readonly="1"/>
                <field name="cheque_numero" widget="char" placeholder="Chiffres uniquement"/>
                <field name="cheque_date_echeance"/>
            </list>
        </field>
    </record>

    <record id="view_pos_cheque_completer_form" model="ir.ui.view">
        <field name="name">pos.payment.cheque.completer.form</field>
        <field name="model">pos.payment</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <form string="Cheque a completer">
                <sheet>
                    <group>
                        <group>
                            <field name="session_id" readonly="1"/>
                            <field name="pos_order_id" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="amount" readonly="1"/>
                            <field name="payment_method_id" readonly="1"/>
                        </group>
                        <group string="Informations cheque">
                            <field name="cheque_numero" placeholder="Chiffres uniquement"/>
                            <field name="cheque_date_echeance"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_pos_cheque_completer_search" model="ir.ui.view">
        <field name="name">pos.payment.cheque.completer.search</field>
        <field name="model">pos.payment</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <search string="Cheques a completer">
                <field name="payment_date"/>
                <field name="session_id"/>
                <field name="pos_order_id"/>
                <field name="partner_id"/>
                <field name="cheque_numero"/>
                <field name="cheque_date_echeance"/>
                <filter name="filter_a_completer" string="A completer"
                        domain="['|', ('cheque_numero', '=', False), ('cheque_date_echeance', '=', False)]"/>
                <filter name="filter_completes" string="Completes"
                        domain="[('cheque_numero', '!=', False), ('cheque_date_echeance', '!=', False)]"/>
                <group>
                    <filter name="group_by_session" string="Session"
                            context="{'group_by': 'session_id'}"/>
                    <filter name="group_by_date" string="Date"
                            context="{'group_by': 'payment_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_pos_cheque_completer" model="ir.actions.act_window">
        <field name="name">Cheques a completer</field>
        <field name="res_model">pos.payment</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('payment_method_id.name', '=', 'cheque')]</field>
        <field name="context">{}</field>
        <field name="search_view_id" ref="view_pos_cheque_completer_search"/>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_pos_cheque_completer_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_pos_cheque_completer_form')})
        ]"/>
    </record>

    <menuitem id="menu_pos_cheque_completer"
              name="Cheques a completer"
              parent="point_of_sale.menu_point_config_product"
              action="action_pos_cheque_completer"
              sequence="20"/>

</odoo>