<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vue liste dédiée, indépendante (pas d'héritage -> pas de conflit
         avec les vues de journal_payment_fields ou customer_special_tax) -->
    <record id="view_account_payment_list_retenue" model="ir.ui.view">
        <field name="name">account.payment.list.retenue</field>
        <field name="model">account.payment</field>
        <field name="arch" type="xml">
            <list string="Retenues à la source"
                  decoration-info="state == 'draft'"
                  decoration-success="state == 'paid'">
                <field name="date"/>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="journal_id"/>
                <field name="amount"/>
                <field name="pourcentage"/>
                <field name="montant_retenue"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Extension MINIME de la vue formulaire standard : on modifie UNIQUEMENT
         l'attribut domain du champ journal_id, rien d'autre (pas de xpath sur
         des tabs/groupes, pas de restructuration). Le domaine lit le context :
         - Depuis le menu "Retenue à la source" (context retenue_only_journals=True) :
           seuls les journaux dont le nom contient "retenue" sont proposés.
         - Depuis le menu Paiements standard (context sans cette clé) :
           l'expression retombe sur [] -> AUCUNE restriction, comportement
           strictement identique à avant. -->
    <record id="view_account_payment_form_retenue_journal_domain" model="ir.ui.view">
        <field name="name">account.payment.form.retenue.journal.domain</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='journal_id']" position="attributes">
                <attribute name="domain">context.get('retenue_only_journals') and [('name', 'ilike', 'retenue')] or []</attribute>
            </xpath>
        </field>
    </record>

    <!-- Action : ouvre account.payment filtré sur le journal "retenue".
         Aucun view_id n'est précisé pour le mode "form" -> Odoo utilisera
         automatiquement la vue formulaire standard (account.view_account_payment_form)
         avec TOUTES les héritances existantes (journal_payment_fields, customer_special_tax).
         C'est cette chaîne d'héritage standard qui gère déjà l'affichage
         conditionnel de l'onglet "Details paiement" et des champs
         pourcentage / montant_retenue via is_retenue_journal. -->
    <record id="action_retenue_source_payments" model="ir.actions.act_window">
        <field name="name">Retenue à la source</field>
        <field name="res_model">account.payment</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_account_payment_list_retenue"/>
        <field name="domain">[('journal_id.name', 'ilike', 'retenue'), ('partner_type', '=', 'customer')]</field>
        <field name="context">{'default_payment_type': 'inbound', 'default_partner_type': 'customer', 'retenue_only_journals': True}</field>
    </record>

    <!-- Même principe côté Fournisseurs : même vue liste réutilisée, même
         extension de vue formulaire (déjà déclarée ci-dessus, elle
         s'applique à account.payment quel que soit le menu). Seul ce qui
         change : domaine/contexte orientés "supplier"/"outbound". -->
    <record id="action_retenue_source_payments_vendors" model="ir.actions.act_window">
        <field name="name">Retenue à la source</field>
        <field name="res_model">account.payment</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_account_payment_list_retenue"/>
        <field name="domain">[('journal_id.name', 'ilike', 'retenue'), ('partner_type', '=', 'supplier')]</field>
        <field name="context">{'default_payment_type': 'outbound', 'default_partner_type': 'supplier', 'retenue_only_journals': True}</field>
    </record>

    <!-- Menu sous Comptabilité > Clients, à côté du menu Paiements standard -->
    <menuitem id="menu_retenue_source"
              name="Retenue à la source"
              parent="account.menu_finance_receivables"
              action="action_retenue_source_payments"
              sequence="15"/>

    <!-- Menu sous Comptabilité > Fournisseurs, à côté du menu Paiements standard -->
    <menuitem id="menu_retenue_source_vendors"
              name="Retenue à la source"
              parent="account.menu_finance_payables"
              action="action_retenue_source_payments_vendors"
              sequence="15"/>

</odoo>
